# Copy to .env and fill in your keys
# Or set globally: schemalock config set ANTHROPIC_API_KEY sk-ant-...

# --- Anthropic (claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (gpt-4o, gpt-4o-mini, gpt-4-turbo, o1, o1-mini, o3-mini) ---
OPENAI_API_KEY=sk-...

# --- Groq (llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768) ---
# Fast inference, very cheap. Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# --- Mistral (mistral-large-latest, mistral-small-latest) ---
MISTRAL_API_KEY=...

# --- Together AI (OpenAI-compatible, 100+ open-source models) ---
TOGETHER_API_KEY=...

# --- Fireworks AI (OpenAI-compatible, fast open-source inference) ---
FIREWORKS_API_KEY=...

# --- Ollama (local, no key needed) ---
# Run locally: ollama serve
# Models: ollama/llama3.2, ollama/mistral, ollama/phi4, ollama/qwen2.5
# Override base URL if not on default port:
# OLLAMA_BASE_URL=http://localhost:11434/v1
